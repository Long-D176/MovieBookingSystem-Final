apiVersion: apps/v1
kind: Deployment
metadata:
  name: adminer
  namespace: ${K8S_NAMESPACE}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: adminer
  template:
    metadata:
      labels:
        app: adminer
    spec:
      containers:
        - name: adminer
          image: adminer
          env:
            - name: ADMINER_DEFAULT_SERVER
              value: db
          ports:
            - containerPort: 8080
---
apiVersion: v1
kind: Service
metadata:
  name: adminer
  namespace: ${K8S_NAMESPACE}
spec:
  selector:
    app: adminer
  ports:
    - port: 8080
      targetPort: 8080
---
