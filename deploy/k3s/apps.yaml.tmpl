        app: frontend
    spec:
      containers:
        - name: frontend
          image: ${IMAGE_NAMESPACE}/${IMAGE_PREFIX}-frontend:${APP_IMAGE_TAG}
          ports:
            - containerPort: 80
          volumeMounts:
            - name: frontend-nginx-conf
              mountPath: /etc/nginx/conf.d/default.conf
